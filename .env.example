# Copy to .env and fill in. Generate secrets with: openssl rand -hex 32
DATABASE_URL="postgresql://daze:daze@localhost:5433/daze?schema=public"

AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# 64 hex chars (32 bytes) — encrypts OAuth tokens and Pushover keys at rest
DAZE_ENCRYPTION_KEY=""

# One Pushover application token shared by the Daze instance
DAZE_PUSHOVER_APP_TOKEN=""

# Google OAuth client with the People API enabled
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/connections/google/callback"

# Optional comma-separated registration allowlist (empty = open registration)
DAZE_ALLOWED_EMAILS=""

# "1" to log notifications instead of sending them
DAZE_DRY_RUN="0"
